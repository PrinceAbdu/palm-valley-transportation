# Supports exact values and wildcard patterns (e.g. https://*.vercel.app).
# Example: CORS_ORIGIN=http://localhost:3000,https://palmvalleytransportationn.vercel.app
CORS_ORIGIN=http://localhost:3000

# Supabase Storage (optional but recommended for image hosting)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=PVTB

# Google OAuth
