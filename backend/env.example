NODE_ENV=development
PORT=4000

# Mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=jacksonville_rides

# Auth
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=7d

# CORS
# In production, set allowed frontend origins (comma-separated).
# Supports exact values and wildcard patterns (e.g. https://*.vercel.app).
# Example: CORS_ORIGIN=http://localhost:3000,https://palmvalleytransportationn.vercel.app
CORS_ORIGIN=http://localhost:3000

